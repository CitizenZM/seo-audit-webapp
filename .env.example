# --- AI synthesis (executive summary, briefs, keyword ideas) ---
ANTHROPIC_API_KEY=

# --- Real SERP intelligence (#4) ---
# googlethis was tried and removed (broken parser + high-severity audit
# findings — see src/lib/serp.ts). SERP data requires a Serper.dev key:
SERPER_API_KEY=

# --- Email reports + scheduled monitoring (#7, via Resend) ---
RESEND_API_KEY=
# Verified sender (defaults to Resend's shared onboarding@resend.dev for testing):
RESEND_FROM=SEO Audit <onboarding@resend.dev>

# Secret that Vercel Cron must present (Authorization: Bearer <CRON_SECRET>):
CRON_SECRET=

# --- Supabase (persisted history, real async job progress, auth, watchlist) ---
# URL + anon key are public/safe-to-ship. Service role key is a SECRET — get
# it from Supabase Dashboard > Project Settings > API > service_role, and
# never expose it to the browser. Without SUPABASE_SERVICE_ROLE_KEY set,
# these features gracefully no-op: history falls back to localStorage only,
# sign-in/watchlist are unavailable, and audits still run synchronously.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Multi-engine visibility probing (optional; each key adds an engine) ---
PERPLEXITY_API_KEY=
# Agnes AI free OpenAI-compatible gateway (https://apihub.agnes-ai.com/v1):
AGNES_API_KEY=
AGNES_MODEL=agnes-2.0-flash

# --- AI crawler analytics: Vercel Log Drain -> POST /api/crawler-logs ---
# (configure the drain with header  x-crawler-secret: <CRAWLER_LOGS_SECRET>)
CRAWLER_LOGS_SECRET=
